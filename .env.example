# Telegram bot
# Token from @BotFather
BOT_TOKEN=your_bot_token

# Database
# Path to local SQLite database file
DB_PATH=data/news_bot.db

# LLM
# URL of your local or remote LLM server
LLM_URL=http://localhost:11434

# Default model name
LLM_MODEL=your_llm_model

# System prompt for news generation
SYSTEM_PROMPT=your_system_prompt

# Webhook
# Host for aiohttp app
HOST=0.0.0.0

# Port for webhook server
PORT=80

# Public webhook URL
WEBHOOK_URL=https://your-domain.example

# Scheduler
# Telegram channel/chat ID for automatic digest posting
DIGEST_CHANNEL_ID=-1001234567890

# Prompt for generating the digest content
DIGEST_PROMPT=your_digest_prompt

# Timezone for scheduled jobs
DIGEST_TIMEZONE=Europe/Moscow
